# ── Environment variables template ────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# .env is gitignored and NEVER committed to the repository.
#
# DEV:  spring-dotenv loads ../.env automatically — no IntelliJ setup needed.
# UAT:  set these as GCP Cloud Run environment variables (no .env file on server).
# PROD: set these as GCP Cloud Run environment variables (no .env file on server).

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=forexbot
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# ── MetaTrader 5 (dev only — replaced by MetaApi in UAT/prod) ─────────────────
MT5_BRIDGE_MT5_LOGIN=your-mt5-account-number
MT5_BRIDGE_MT5_PASSWORD=your-mt5-password
MT5_BRIDGE_MT5_SERVER=MetaQuotes-Demo

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Add Authorised redirect URI: http://localhost:8080/login/oauth2/code/google
# Leave as "disabled" to skip Google login and use username/password only.
GOOGLE_CLIENT_ID=disabled
GOOGLE_CLIENT_SECRET=disabled

# ── Email — Brevo SMTP ────────────────────────────────────────────────────────
# Brevo setup:
#   1. Log in at https://app.brevo.com → Settings → SMTP & API → SMTP tab
#   2. Generate a new SMTP key — that becomes MAIL_PASSWORD
#   3. MAIL_USERNAME = your Brevo account login email (not the SMTP key name)
#   4. MAIL_FROM = a verified sender domain/address configured in Brevo
# Leave MAIL_USERNAME blank in dev to skip sending and log links to console instead.
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login@example.com
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_FROM=noreply@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
SERVER_PORT=8080

# ── Service URLs ──────────────────────────────────────────────────────────────
MT5_BRIDGE_URL=http://localhost:8001
SIGNAL_ENGINE_URL=http://localhost:8002
SIGNAL_MT5_BRIDGE_URL=http://localhost:8001
SIGNAL_BACKEND_URL=http://localhost:8080

# ── Signal engine ─────────────────────────────────────────────────────────────
SIGNAL_SYMBOLS=["EURUSD","GBPUSD","USDJPY","AUDUSD"]
SIGNAL_TIMEFRAME=H1

# ── Bot ───────────────────────────────────────────────────────────────────────
PAPER_TRADING=true
SCAN_INTERVAL=60
DEFAULT_VOLUME=0.01
SL_PIPS=30.0
TP_PIPS=60.0
MAX_OPEN_TRADES=3
