# ── MetaTrader 5 credentials ──────────────────────────────────
MT5_BRIDGE_MT5_LOGIN=12345678
MT5_BRIDGE_MT5_PASSWORD=your_mt5_password
MT5_BRIDGE_MT5_SERVER=YourBroker-Demo

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=forexbot
DB_USER=forexbot
DB_PASSWORD=changeme_strong_password

# ── Service URLs (defaults match docker-compose) ──────────────
MT5_BRIDGE_URL=http://mt5-bridge:8001
SIGNAL_ENGINE_URL=http://signal-engine:8002

# ── Signal engine settings ────────────────────────────────────
SIGNAL_MT5_BRIDGE_URL=http://mt5-bridge:8001
SIGNAL_BACKEND_URL=http://backend:8080
SIGNAL_SYMBOLS=["EURUSD","GBPUSD","USDJPY","AUDUSD"]
SIGNAL_TIMEFRAME=H1

# ── Bot settings ──────────────────────────────────────────────
PAPER_TRADING=true          # Set to false ONLY after thorough testing!
SCAN_INTERVAL=60            # Seconds between signal polls
DEFAULT_VOLUME=0.01         # Lot size
SL_PIPS=30.0
TP_PIPS=60.0
MAX_OPEN_TRADES=3
