# Python virtual environments
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/

# ML models (large binary files — retrain per environment)
signal-engine/models/

# Environment secrets — never commit these
.env
# .env.example IS committed — it's the template with fake values

# Local overrides (if you need machine-specific tweaks beyond .env)
backend/src/main/resources/application-local.yml

# application-dev.yml is gitignored because it may contain local path tweaks.
# It has NO secrets — all secrets live in .env.
# New team members: copy application-dev.yml.example (if present) or create from scratch.
backend/src/main/resources/application-dev.yml

# Java / Maven
backend/target/
*.class

# IDE
.idea/
*.iml
.vscode/

# Docker volumes
mysql_data/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
